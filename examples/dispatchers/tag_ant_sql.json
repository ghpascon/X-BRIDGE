{
    "_usage": {
        "description": "SQL dispatch example for tag events filtered by antenna.",
        "notes": [
            "This dispatch is triggered only for tag events from selected antennas.",
            "Use bound parameters in query and do not interpolate raw values."
        ],
        "async_connection_string_examples": {
            "postgresql": "postgresql+asyncpg://user:password@localhost:5432/mydatabase",
            "mysql": "mysql+aiomysql://user:password@localhost:3306/mydatabase",
            "sqlite": "sqlite+aiosqlite:///./mydatabase.db"
        },
        "filter_operators": [
            "eq",
            "ne",
            "in",
            "not_in",
            "gt",
            "lt",
            "gte",
            "lte",
            "contains"
        ]
    },
    "dispatch_type": "sql",
    "connection_string": "postgresql+asyncpg://user:password@localhost:5432/mydatabase",
    "on_event": "tag",
    "filters": [
        {
            "_description": "Only dispatch tags read on antenna 1 or 2.",
            "key": "{data[ant]}",
            "value": [
                1,
                2
            ],
            "operator": "in"
        }
    ],
    "query": "INSERT INTO tag_events (device, epc, tid, ant, rssi, timestamp) VALUES (:device, :epc, :tid, :ant, :rssi, :timestamp)",
    "params": {
        "device": "{name}",
        "epc": "{data[epc]}",
        "tid": "{data[tid]}",
        "ant": "{data[ant]}",
        "rssi": "{data[rssi]}",
        "timestamp": "{data[timestamp]}"
    }
}